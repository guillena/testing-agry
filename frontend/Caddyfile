{
	# Disable the Caddy admin API (not needed in production)
	admin off

	# Log to stdout for Railway log aggregation
	log {
		output stdout
		format console
		level INFO
	}
}

:3000 {
	root * /app/dist

	# Enable file server
	file_server

	# Cache static assets (JS, CSS, images, fonts) aggressively
	@assets {
		path /assets/*
	}
	header @assets Cache-Control "public, max-age=31536000, immutable"

	# Cache other static files (favicon, icons, etc.) briefly
	@static {
		path *.svg *.png *.ico *.webp *.woff *.woff2
	}
	header @static Cache-Control "public, max-age=86400"

	# SPA fallback: serve index.html for any path that doesn't match a real file
	try_files {path} /index.html

	# Log requests
	log {
		output stdout
		format console
	}
}
